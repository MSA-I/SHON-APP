{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "image-library",
  "description": "READ-ONLY access to the on-disk image library (7 category folders + 2 loose root JPGs). Enforces the 'MUST keep images in their existing folders' behavioral rule (claude.md #2). NEVER add a write permission to this file — that breaks the read-only invariant. Companion: capabilities/app-writable.json. SOP: architecture/08-tauri-filesystem.md § Path Scopes #1. Each category folder needs both the bare path (for readDir) and the /** glob (for file reads).",
  "windows": ["main"],
  "permissions": [
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-stat",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "C:/Users/sara/Desktop/שון בלאיש/אולם עיצוב בסיס 2026" },
        { "path": "C:/Users/sara/Desktop/שון בלאיש/אולם עיצוב בסיס 2026/**" },
        { "path": "C:/Users/sara/Desktop/שון בלאיש/חופות אולם גדול גאמוס" },
        { "path": "C:/Users/sara/Desktop/שון בלאיש/חופות אולם גדול גאמוס/**" },
        { "path": "C:/Users/sara/Desktop/שון בלאיש/חופות ריזורט" },
        { "path": "C:/Users/sara/Desktop/שון בלאיש/חופות ריזורט/**" },
        { "path": "C:/Users/sara/Desktop/שון בלאיש/חופות שידרוג" },
        { "path": "C:/Users/sara/Desktop/שון בלאיש/חופות שידרוג/**" },
        { "path": "C:/Users/sara/Desktop/שון בלאיש/מפות מפיות" },
        { "path": "C:/Users/sara/Desktop/שון בלאיש/מפות מפיות/**" },
        { "path": "C:/Users/sara/Desktop/שון בלאיש/עיצובים שידרוג" },
        { "path": "C:/Users/sara/Desktop/שון בלאיש/עיצובים שידרוג/**" },
        { "path": "C:/Users/sara/Desktop/שון בלאיש/ריזורט בסיס" },
        { "path": "C:/Users/sara/Desktop/שון בלאיש/ריזורט בסיס/**" },
        { "path": "C:/Users/sara/Desktop/שון בלאיש/כסא כלה בחוץ בסיס.jpg" },
        { "path": "C:/Users/sara/Desktop/שון בלאיש/כסא כלה בתוך האולם.jpg" }
      ]
    }
  ]
}
