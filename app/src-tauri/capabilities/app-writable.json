{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "app-writable",
  "description": "READ-WRITE access strictly limited to events/ and backups/ — the only two folders the app writes. NEVER add image-library paths to this scope; writes there are forbidden by claude.md #2. `fs:allow-rename` is required by the atomic-write pattern (write to .tmp → rename to final), per SOP 08 § Atomic Writes. `fs:allow-remove` is required for backup retention pruning (rolling 30) and is gated at the lib level so events/*.docx cannot be removed. Companion: capabilities/image-library.json. SOP: architecture/08-tauri-filesystem.md § Path Scopes #2. As of 2026-05-24, scope is widened from a single absolute path to multi-drive globs because the project root is now resolved at runtime by lib/config.ts. Defense-in-depth at the lib layer (assertInsideRoot in tauri-fs.ts) enforces every write stays inside the resolved root. See claude.md Maintenance Log 2026-05-24.",
  "windows": ["main"],
  "permissions": [
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-read-dir",
    "fs:allow-stat",
    "fs:allow-exists",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-rename",
    "fs:allow-remove",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/Desktop/שון בלאיש/events" },
        { "path": "$HOME/Desktop/שון בלאיש/events/**" },
        { "path": "$HOME/Desktop/שון בלאיש/backups" },
        { "path": "$HOME/Desktop/שון בלאיש/backups/**" },
        { "path": "$HOME/OneDrive/Desktop/שון בלאיש/events" },
        { "path": "$HOME/OneDrive/Desktop/שון בלאיש/events/**" },
        { "path": "$HOME/OneDrive/Desktop/שון בלאיש/backups" },
        { "path": "$HOME/OneDrive/Desktop/שון בלאיש/backups/**" },
        { "path": "$HOME/Documents/שון בלאיש/events" },
        { "path": "$HOME/Documents/שון בלאיש/events/**" },
        { "path": "$HOME/Documents/שון בלאיש/backups" },
        { "path": "$HOME/Documents/שון בלאיש/backups/**" },
        { "path": "$HOME/OneDrive/Documents/שון בלאיש/events" },
        { "path": "$HOME/OneDrive/Documents/שון בלאיש/events/**" },
        { "path": "$HOME/OneDrive/Documents/שון בלאיש/backups" },
        { "path": "$HOME/OneDrive/Documents/שון בלאיש/backups/**" },
        { "path": "$HOME/שון בלאיש/events" },
        { "path": "$HOME/שון בלאיש/events/**" },
        { "path": "$HOME/שון בלאיש/backups" },
        { "path": "$HOME/שון בלאיש/backups/**" },
        { "path": "C:/שון בלאיש/events" },
        { "path": "C:/שון בלאיש/events/**" },
        { "path": "C:/שון בלאיש/backups" },
        { "path": "C:/שון בלאיש/backups/**" },
        { "path": "D:/שון בלאיש/events" },
        { "path": "D:/שון בלאיש/events/**" },
        { "path": "D:/שון בלאיש/backups" },
        { "path": "D:/שון בלאיש/backups/**" },
        { "path": "E:/שון בלאיש/events" },
        { "path": "E:/שון בלאיש/events/**" },
        { "path": "E:/שון בלאיש/backups" },
        { "path": "E:/שון בלאיש/backups/**" },
        { "path": "F:/שון בלאיש/events" },
        { "path": "F:/שון בלאיש/events/**" },
        { "path": "F:/שון בלאיש/backups" },
        { "path": "F:/שון בלאיש/backups/**" },
        { "path": "D:/משה פרוייקטים/שון בלאיש/events" },
        { "path": "D:/משה פרוייקטים/שון בלאיש/events/**" },
        { "path": "D:/משה פרוייקטים/שון בלאיש/backups" },
        { "path": "D:/משה פרוייקטים/שון בלאיש/backups/**" },
        { "path": "F:/MyFiles/העסק שלי/שון בלאיש/events" },
        { "path": "F:/MyFiles/העסק שלי/שון בלאיש/events/**" },
        { "path": "F:/MyFiles/העסק שלי/שון בלאיש/backups" },
        { "path": "F:/MyFiles/העסק שלי/שון בלאיש/backups/**" }
      ]
    }
  ]
}
